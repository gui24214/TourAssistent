{
  "kind": "collectionType",
  "collectionName": "areas",
  "info": {
    "singularName": "area",
    "pluralName": "areas",
    "displayName": "Area"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "descricao": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "audio": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files",
        "audios"
      ]
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area",
      "inversedBy": "areas"
    },
    "areas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::area.area",
      "mappedBy": "area"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item.item",
      "mappedBy": "area"
    },
    "tour": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tour.tour",
      "inversedBy": "areas"
    }
